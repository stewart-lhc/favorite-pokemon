{
  "name": "favorite-pokemon",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "brand:assets": "node scripts/generate-brand-assets.mjs",
    "seo:assets": "node scripts/generate-seo-assets.mjs",
    "seo:routes": "node scripts/generate-seo-routes.mjs",
    "build": "npm run seo:assets && tsc -b && vite build && npm run seo:routes",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "check": "npm run test && npm run build",
    "db:migrate": "node scripts/apply-declaration-rate-limits-migration.mjs",
    "pokemon:assets": "node scripts/cache-pokemon-assets.mjs",
    "sync:pokemon": "node scripts/sync-pokemon-data.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.3.0",
    "playwright": "^1.57.0",
    "sharp": "^0.35.1",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.0.15"
  }
}
